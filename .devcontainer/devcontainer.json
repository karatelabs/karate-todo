{
    "name": "karate-todo",
    "image": "mcr.microsoft.com/devcontainers/java:1-21-bullseye",

    "features": {
        "ghcr.io/devcontainers/features/java:1": {
            "version": "none",
            "installMaven": "true",
            "installGradle": "false"
        },
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },

    "forwardPorts": [8080, 5500],

    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.java",
                "karatelabs.karate",
                "ms-vscode.live-server"
            ]
        }
    }
}
